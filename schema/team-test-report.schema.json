{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vgc.tests/team-test-report.schema.json",
  "title": "VGC Team Test Report",
  "description": "The result of evaluating a team-test suite against one team. Per-test pass/fail plus WITNESSES (which members satisfied a test; which group elements are uncovered). The witnesses are exactly what a future suggestion/optimizer consumes: for each failing test, search the legal candidate pool for mons that flip the failing predicate.",
  "type": "object",
  "required": ["suite", "passed", "results"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "suite": { "type": "string", "description": "Suite name or id that was run." },
    "team": {
      "description": "The team under test: an opaque id, or a lightweight slot summary.",
      "oneOf": [
        { "type": "string" },
        {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["slot", "species"],
            "properties": {
              "slot": { "type": "integer", "minimum": 0 },
              "species": { "$ref": "#/$defs/Id" }
            }
          }
        }
      ]
    },
    "format": { "type": "string", "pattern": "^[a-z0-9]+$" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "passed": { "type": "boolean", "description": "True iff every error-severity test passed." },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "error": { "$ref": "#/$defs/Tally" },
        "warn": { "$ref": "#/$defs/Tally" },
        "info": { "$ref": "#/$defs/Tally" }
      }
    },
    "results": { "type": "array", "items": { "$ref": "#/$defs/Result" } }
  },
  "$defs": {
    "Id": { "type": "string", "pattern": "^[a-z0-9]+$" },
    "Op": { "type": "string", "enum": [">=", "<=", ">", "<", "==", "!="] },
    "Tally": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "MemberRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slot", "species"],
      "properties": {
        "slot": { "type": "integer", "minimum": 0 },
        "species": { "$ref": "#/$defs/Id" }
      }
    },
    "Result": {
      "type": "object",
      "required": ["id", "pass"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "severity": { "type": "string", "enum": ["error", "warn", "info"] },
        "weight": { "type": "number", "minimum": 0 },
        "pass": { "type": "boolean" },
        "actual": { "type": "number", "description": "The measured count/distinct-count for count-style assertions." },
        "op": { "$ref": "#/$defs/Op" },
        "value": { "type": "number", "description": "The threshold compared against." },
        "satisfiedBy": {
          "type": "array",
          "description": "Members that satisfied the test's predicate (count/countDistinct/team).",
          "items": { "$ref": "#/$defs/MemberRef" }
        },
        "coverage": {
          "type": "object",
          "description": "For coverage assertions: which group elements were/weren't handled.",
          "additionalProperties": false,
          "properties": {
            "of": { "type": "string", "enum": ["all", "any"] },
            "atLeast": { "type": "integer", "minimum": 1 },
            "covered": { "type": "array", "items": { "type": "string" } },
            "uncovered": { "type": "array", "items": { "type": "string" }, "description": "The gap — drives the suggestion button / marilland-style highlighting." },
            "byElement": {
              "type": "object",
              "description": "element -> members that handled it.",
              "additionalProperties": { "type": "array", "items": { "$ref": "#/$defs/MemberRef" } }
            }
          }
        },
        "message": { "type": "string" },
        "detail": { "type": "object", "additionalProperties": true, "description": "Free-form evaluator detail (e.g. damage rolls, computed speeds)." }
      }
    }
  }
}
