{
  "$schema": "https://vgc.tests/team-test-suite.schema.json",
  "$comment": "Damage calcs you must SURVIVE. Atoms: survives, typeEffectiveness (vsThreat). Assertions: count, coverage (threats group). Threats use set:'usage' for low-friction spreads; chomp also models the after-Intimidate variation.",
  "schemaVersion": "1.0.0",
  "name": "Survival calcs",
  "definitions": {
    "threats": {
      "chomp_dragonclaw": {
        "species": "garchomp",
        "move": "dragonclaw",
        "set": "usage",
        "variations": [{ "name": "after Intimidate", "boosts": { "atk": -1 } }]
      },
      "urshifu_suckerpunch": {
        "species": "urshifu",
        "move": "suckerpunch",
        "set": "usage"
      },
      "rilla_grassyglide": {
        "species": "rillaboom",
        "move": "grassyglide",
        "set": "usage"
      },
      "dnite_extremespeed": {
        "species": "dragonite",
        "move": "extremespeed",
        "set": "usage"
      }
    },
    "groups": {
      "common_priority": {
        "kind": "threats",
        "members": [
          "urshifu_suckerpunch",
          "rilla_grassyglide",
          "dnite_extremespeed"
        ]
      }
    }
  },
  "tests": [
    {
      "id": "two-survive-chomp-dclaw",
      "title": "2 mons survive Garchomp Dragon Claw",
      "rationale": "case:worst picks the most damaging variation (the non-Intimidated calc); roll:max means even the high roll leaves >0 HP.",
      "assert": {
        "count": "members",
        "where": {
          "kind": "survives",
          "threat": "chomp_dragonclaw",
          "case": "worst",
          "roll": "max"
        },
        "op": ">=",
        "value": 2
      }
    },
    {
      "id": "a-wall-survives-two-hits",
      "title": "Someone eats two Dragon Claws",
      "rationale": "hits:2 — a dedicated check that one member survives the threat twice.",
      "severity": "info",
      "assert": {
        "count": "members",
        "where": {
          "kind": "survives",
          "threat": "chomp_dragonclaw",
          "hits": 2,
          "roll": "max"
        },
        "op": ">=",
        "value": 1
      }
    },
    {
      "id": "resist-common-priority",
      "title": "Every common priority attack is resisted by someone",
      "rationale": "Coverage over a threat group; each priority attack must be RESISTED (vsThreat resolves the threat's move type) OR SURVIVED by some member.",
      "assert": {
        "coverage": {
          "group": "common_priority",
          "each": {
            "kind": "any",
            "of": [
              {
                "kind": "typeEffectiveness",
                "role": "defending",
                "vsThreat": "$each",
                "op": "<=",
                "value": 0.5
              },
              { "kind": "survives", "threat": "$each", "roll": "max" }
            ]
          },
          "atLeast": 1
        }
      }
    }
  ]
}
